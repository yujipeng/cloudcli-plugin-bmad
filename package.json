{
  "name": "bmad-flow",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "esbuild src/index.ts --bundle --format=esm --outfile=dist/index.js --platform=browser && esbuild src/server.ts --bundle --format=esm --outfile=dist/server.js --platform=node --packages=external",
    "dev": "tsc --watch",
    "test": "vitest --run"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^20.0.0",
    "esbuild": "^0.25.0",
    "typescript": "^5.5.0",
    "vitest": "^4.1.5"
  }
}
